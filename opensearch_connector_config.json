    "value.converter.schema.registry.url": "https://<kafka_host>:14702",
    "value.converter.basic.auth.credentials.source": "USER_INFO",
    "value.converter.schema.registry.basic.auth.user.info": "avnadmin:<password>",
    "topics": "clickstream",
    "write.method": "insert"
}
